        STEGO_CMD="$STEGO_CMD --carrier $_CARRIER"
    else
        STEGO_CMD="$STEGO_CMD --auto-carrier"
    fi
    STEGO_CMD="$STEGO_CMD --out $OUT_IMG"

    local STEGO_OUT
    STEGO_OUT=$(eval "$STEGO_CMD" 2>&1)
    echo "$STEGO_OUT" | sed 's/^/    /'

    local KEY_B64
    KEY_B64=$(echo "$STEGO_OUT" | grep "XOR key" | awk '{print $NF}')

    if [ -f "$OUT_IMG" ] && [ -n "$KEY_B64" ]; then
        echo ""
        ok "Stego image: ${W}$OUT_IMG${N}"
        echo -e "  ${C}XOR key:${N} $KEY_B64"

