              done)
        # fallback
        [ -z "$MY_IP" ] && MY_IP=$(ip route get 8.8.8.8 2>/dev/null \
            | awk '/src/{for(i=1;i<=NF;i++) if($i=="src"){print $(i+1);exit}}')
        physical_arp_keylogger
        ;;
    "")             main ;;
