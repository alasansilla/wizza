# ── kernel check — enumerate kernel CVEs and local attack surface ──────
kernel_check() {
    banner
    echo -e "  ${W}KERNEL VULNERABILITY SCANNER${N}\n"

    local kver
    kver=$(uname -r)
    info "Kernel: ${W}$kver${N}"
    info "Arch:   $(uname -m)"
    info "Host:   $(hostname)  User: $(whoami)  UID: $(id -u)"
    echo ""

    # Parse version numbers for comparison
    local maj min patch
    maj=$(echo "$kver" | cut -d. -f1)
    min=$(echo "$kver" | cut -d. -f2)
    patch=$(echo "$kver" | cut -d. -f3 | grep -o '^[0-9]*')

    local ver_num=$(( maj * 100000 + min * 1000 + patch ))
    local found=0

    echo -e "  ${W}CVE Check:${N}"

    # DirtyCow CVE-2016-5195: 2.6.22 – 4.8.3
    local dc_min=$(( 2*100000 + 6*1000 + 22 ))
    local dc_max=$(( 4*100000 + 8*1000 + 3 ))
    if [ "$ver_num" -ge "$dc_min" ] && [ "$ver_num" -le "$dc_max" ]; then
        echo -e "  ${R}[VULN]${N} CVE-2016-5195  DirtyCow          kernel $kver  → local root via /etc/passwd"
        found=1
    else
        echo -e "  ${G}[SAFE]${N} CVE-2016-5195  DirtyCow          (need 2.6.22–4.8.3)"
    fi

    # DirtyPipe CVE-2022-0847: 5.8.0 – 5.16.11 / 5.15.0–5.15.25 / 5.10.0–5.10.102
    local dp_min=$(( 5*100000 + 8*1000 + 0 ))
    local dp_max=$(( 5*100000 + 16*1000 + 11 ))
    if [ "$ver_num" -ge "$dp_min" ] && [ "$ver_num" -le "$dp_max" ]; then
        echo -e "  ${R}[VULN]${N} CVE-2022-0847  DirtyPipe         kernel $kver  → arbitrary file overwrite"
        found=1
    else
        echo -e "  ${G}[SAFE]${N} CVE-2022-0847  DirtyPipe         (need 5.8–5.16.11)"
    fi

    # OverlayFS CVE-2021-3493: Ubuntu-specific, check distro
    if grep -qi ubuntu /etc/os-release 2>/dev/null; then
        local ubuntu_ver
        ubuntu_ver=$(grep VERSION_ID /etc/os-release 2>/dev/null | cut -d'"' -f2)
        case "$ubuntu_ver" in
            16.04|18.04|20.04|20.10)
                echo -e "  ${R}[VULN]${N} CVE-2021-3493  OverlayFS         Ubuntu $ubuntu_ver  → cap_setuid via overlayfs xattr"
                found=1 ;;
            *)
                echo -e "  ${G}[SAFE]${N} CVE-2021-3493  OverlayFS         (Ubuntu $ubuntu_ver likely patched)" ;;
        esac
    else
        echo -e "  ${C}[INFO]${N} CVE-2021-3493  OverlayFS         not Ubuntu — check manually"
    fi

    # Looney Tunables CVE-2023-4911: glibc 2.34–2.38
    echo ""
    echo -e "  ${W}glibc Check:${N}"
    local glibc_ver
    glibc_ver=$(ldd --version 2>/dev/null | head -1 | awk '{print $NF}')
    if [ -n "$glibc_ver" ]; then
        local gm gn
        gm=$(echo "$glibc_ver" | cut -d. -f1)
        gn=$(echo "$glibc_ver" | cut -d. -f2)
        if [ "$gm" -eq 2 ] && [ "$gn" -ge 34 ] && [ "$gn" -le 38 ]; then
            echo -e "  ${R}[VULN]${N} CVE-2023-4911  Looney Tunables   glibc $glibc_ver  → setuid heap overflow → root"
            found=1
        else
            echo -e "  ${G}[SAFE]${N} CVE-2023-4911  Looney Tunables   (glibc $glibc_ver)"
        fi
    fi

    # PwnKit CVE-2021-4034: pkexec
    echo ""
    echo -e "  ${W}SUID / Capability Scan:${N}"
    if command -v pkexec &>/dev/null; then
        local pk_ver
        pk_ver=$(pkexec --version 2>&1 | awk '{print $NF}')
        echo -e "  ${R}[VULN]${N} CVE-2021-4034  PwnKit (pkexec)   v$pk_ver  → local root, all Linux distros since 2009"
        found=1
    fi

    # SUID binaries
    local suids
    suids=$(find /usr/bin /usr/sbin /bin /sbin -perm -4000 2>/dev/null | tr '\n' ' ')
    if [ -n "$suids" ]; then
        echo -e "  ${C}[INFO]${N} SUID binaries:  $suids"
    fi

    # World-writable files in sensitive paths
    local ww
    ww=$(find /etc /usr/bin /usr/sbin -writable 2>/dev/null | head -5)
    if [ -n "$ww" ]; then
        echo -e "  ${R}[VULN]${N} World-writable: $ww"
        found=1
    fi

    # Sudo rights
    echo ""
    echo -e "  ${W}Sudo:${N}"
    sudo -l 2>/dev/null | grep -v "^Matching\|^User\|^[[:space:]]*$" | \
        sed 's/^/  /' | head -10
    if sudo -l 2>/dev/null | grep -q NOPASSWD; then
        echo -e "  ${R}[VULN]${N} NOPASSWD sudo entry found — check above"
        found=1
    fi

    # Writable crontabs
    echo ""
    echo -e "  ${W}Cron:${N}"
    for cf in /etc/crontab /etc/cron.d/* /var/spool/cron/crontabs/*; do
        [ -w "$cf" ] 2>/dev/null && echo -e "  ${R}[VULN]${N} Writable cron: $cf" && found=1
    done

    echo ""
    if [ "$found" -eq 0 ]; then
        ok "No obvious vulnerabilities found (try suggestor tools: linpeas, linux-exploit-suggester)"
    else
        warn "Vulnerabilities found — use ${W}start kernel exploit${N} to exploit"
    fi
    echo ""
}

