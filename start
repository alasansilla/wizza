# ── STEP 0: Anonymity ────────────────────────────────────────
check_anonymity() {
    while true; do
        banner
        step 0 "ANONYMITY CHECK"
        echo ""
        info "Checking Tor status..."
        echo ""

        if ! pgrep -f "tor.*SocksPort 9060" > /dev/null 2>&1; then
            # Fetch IP with tight timeout — don't block the UI
            _REAL_IP=$(curl -s --max-time 4 --connect-timeout 3 \
                https://api.ipify.org 2>/dev/null \
                || curl -s --max-time 4 --connect-timeout 3 \
                http://checkip.amazonaws.com 2>/dev/null \
                || echo "unknown")
            echo -e "  ${R}╔══════════════════════════════════════════════╗${N}"
            echo -e "  ${R}║  ⚠  TOR IS NOT RUNNING — REAL IP EXPOSED    ║${N}"
            echo -e "  ${R}╚══════════════════════════════════════════════╝${N}"
            echo ""
            err "Real IP : $_REAL_IP  ← EXPOSED"
            echo ""
            echo -e "  ${C}[1]${N} Start Tor now (auto)"
            echo -e "  ${C}[2]${N} Skip — I'm on a test/lab network, proceed anyway"
            echo ""
            echo -n "  > "
            read -r TOR_CHOICE
            case "$TOR_CHOICE" in
                2)
                    warn "Skipping anonymity check — real IP will be visible"
                    break
                    ;;
                1|*)
                    info "Starting Tor..."
                    mkdir -p /tmp/tord
                    nohup tor --SocksPort 9060 --ControlPort 9061 \
                        --DataDirectory /tmp/tord --Log "notice stdout" \
                        > /tmp/tord/tor.log 2>&1 &
                    info "Waiting for bootstrap (up to 40s)..."
                    for i in $(seq 1 20); do
                        sleep 2
                        if grep -q "Bootstrapped 100%" /tmp/tord/tor.log 2>/dev/null; then
                            ok "Tor bootstrapped!"
                            break
                        fi
                        pct=$(grep -o 'Bootstrapped [0-9]*%' /tmp/tord/tor.log 2>/dev/null | tail -1)
                        printf "  %s\r" "${pct:-starting...}"
                    done
                    echo ""
                    ;;
            esac
            continue
        fi

        REAL_IP=$(curl -s --max-time 8 http://checkip.amazonaws.com 2>/dev/null | \
            grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -1)
        TOR_IP=$(curl -s --max-time 15 --proxy socks5h://127.0.0.1:9060 \
            http://checkip.amazonaws.com 2>/dev/null | \
            grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -1)

        if [ -z "$TOR_IP" ] || [ "$TOR_IP" = "$REAL_IP" ]; then
            echo -e "  ${R}╔══════════════════════════════════════════════╗${N}"
            echo -e "  ${R}║  ⚠  TOR NOT ROUTING — REAL IP EXPOSED       ║${N}"
            echo -e "  ${R}╚══════════════════════════════════════════════╝${N}"
            echo ""
            err "Real IP  : ${REAL_IP}  ← EXPOSED"
            err "Tor exit : ${TOR_IP:-UNREACHABLE}"
            echo ""
            warn "Tor circuits are broken."
            echo ""
            echo -e "  ${C}[R]${N} Rotate Tor circuit (get new exit node)"
            echo -e "  ${C}[S]${N} Restart Tor completely"
            echo -e "  ${C}[Enter]${N} Recheck (if you already fixed it)"
            echo ""
            echo -n "  > "
            read -r FIX_CHOICE
            case "${FIX_CHOICE,,}" in
                r)
                    info "Rotating circuit..."
                    echo -e "AUTHENTICATE \"\"\r\nSIGNAL NEWNYM\r\nQUIT" | \
                        nc 127.0.0.1 9061 2>/dev/null && ok "NEWNYM signal sent" || warn "Control port unreachable"
                    info "Waiting 8s for new circuit..."
                    sleep 8
                    ;;
                s)
                    info "Restarting Tor..."
                    pkill -f "tor.*SocksPort 9060" 2>/dev/null
                    sleep 2
                    nohup tor --SocksPort 9060 --ControlPort 9061 \
                        --DataDirectory /tmp/tord --Log "notice stdout" \
                        > /tmp/tord/tor.log 2>&1 &
                    info "Waiting for bootstrap..."
                    for i in $(seq 1 20); do
                        sleep 2
                        grep -q "Bootstrapped 100%" /tmp/tord/tor.log 2>/dev/null && \
                            ok "Bootstrapped!" && break
                        printf "  [%ds] %s\r" $((i*2)) \
                            "$(grep -o 'Bootstrapped [0-9]*%' /tmp/tord/tor.log 2>/dev/null | tail -1)"
                    done
                    echo ""
                    ;;
            esac
            continue
        fi

        GEO=$(curl -s --max-time 8 "https://ipapi.co/$TOR_IP/json/" 2>/dev/null | \
              python3 -c "import sys,json; d=json.load(sys.stdin); print(f\"{d.get('country_name','?')}, {d.get('city','?')}\")" 2>/dev/null)

        echo -e "  ${G}╔══════════════════════════════════════════════╗${N}"
        echo -e "  ${G}║  ✓  ANONYMOUS — safe to proceed             ║${N}"
        echo -e "  ${G}╚══════════════════════════════════════════════╝${N}"
        echo ""
        ok "Real IP  : $REAL_IP  (hidden from target)"
        ok "Tor exit : $TOR_IP  ($GEO)"
        echo ""
        log "Anonymity verified — exit: $TOR_IP ($GEO)"
        wait_key
        break
    done
}

