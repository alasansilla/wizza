}

# ── Entry point — dispatch command or run wizard ─────────────
CMD="${1:-}"
case "$CMD" in
    help|--help|-h) init_files; cmd_help ;;
    up)             init_files; cmd_up ;;
    mitm)           cmd_mitm ;;
    payload)        init_files; cmd_payload ;;
    down)           cmd_down ;;
    status)         init_files; cmd_status ;;
